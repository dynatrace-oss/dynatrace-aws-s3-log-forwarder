{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "commitMessageExtra": "{{#if currentVersion}}from {{currentVersion}} {{/if}}to {{#if isSingleVersion}}{{{newVersion}}}{{else}}{{{newValue}}}{{/if}}",
  "prHourlyLimit": 0,
  "rebaseWhen": "conflicted",
  "pip_requirements": {
    "managerFilePatterns": [
      "/(^|/)([\\w-]*)requirements(-dev)?\\.(txt|pip)$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Lambda Python image tag in build_docker.sh",
      "managerFilePatterns": [
        "/^scripts/build_docker\\.sh$/"
      ],
      "matchStrings": [
        "LAMBDA_RUNTIME_IMAGE=\"(?<depName>public\\.ecr\\.aws/lambda/python):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+(?:\\.\\d+)*)(?:-(?<build>.+))?$"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  }
}
